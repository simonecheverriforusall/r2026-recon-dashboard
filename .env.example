# ── Jira ─────────────────────────────────────────────────────────────────────
# Your Atlassian Cloud URL (no trailing slash)
JIRA_BASE_URL=https://forusall401k.atlassian.net

# The email you use to log in to Jira
JIRA_EMAIL=your.email@company.com

# API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# Jira project key for the Reconciliation project
JIRA_PROJECT_KEY=R2026

# ── Auth (Google OAuth — @forusall.com only) ─────────────────────────────────
# Set REQUIRE_AUTH=false for local dev without login
REQUIRE_AUTH=true
SESSION_SECRET=generate-a-long-random-string-here
ALLOWED_EMAIL_DOMAIN=forusall.com

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect URI: https://<your-host>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: force redirect/callback base URL (Render sets X-Forwarded-* automatically)
# APP_BASE_URL=https://r2026-recon-dashboard.onrender.com

# ── Snowflake (RSA keypair — same key as snow CLI) ───────────────────────────
# Connectivity test: GET /api/snowflake/test (requires login when REQUIRE_AUTH=true)
SNOWFLAKE_ENABLED=false
SNOWFLAKE_ACCOUNT=your_account_locator
SNOWFLAKE_USER=your_snowflake_username
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# Use recon_project profile for PLANS_IN_BUCKET:
SNOWFLAKE_ROLE=OPS_DEV
SNOWFLAKE_DATABASE=RECON_PROJECT
SNOWFLAKE_SCHEMA=CONTROL

# Private key: use ONE of the following (never commit real values)
# SNOWFLAKE_PRIVATE_KEY="-----BEGIN ENCRYPTED PRIVATE KEY-----\n...\n-----END ENCRYPTED PRIVATE KEY-----"
# SNOWFLAKE_PRIVATE_KEY_BASE64=   # base64 of full PEM file (good for Render secrets)
# SNOWFLAKE_PRIVATE_KEY_PATH=~/.snowflake/keys/cli_key.p8   # local dev only
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# ── Communications (DevRev + Drive gates) ─────────────────────────────────────
RECON_YEAR=2026
COMMUNICATIONS_DRY_RUN=true
DEVREV_ENABLED=false
DEVREV_API_TOKEN=
DRIVE_COMM_REQUIRED_PATTERN=
# DRIVE_TOKEN_PATH=

# ── Supabase (project: recon-dashboard) ───────────────────────────────────────
COMMS_USE_SUPABASE=true
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
COMMS_CACHE_TTL_HOURS=6
COMMS_SYNC_SECRET=generate-a-long-random-string
# Render cron: POST /api/communications/sync-all?secret=... every 6h (0 */6 * * *)
# COMMS_TRACKER_CSV=../reconciliation/Year_end_comm_tracker - DB.csv
