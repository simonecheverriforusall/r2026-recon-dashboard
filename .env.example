# ── Jira ─────────────────────────────────────────────────────────────────────
# Your Atlassian Cloud URL (no trailing slash)
JIRA_BASE_URL=https://forusall401k.atlassian.net

# The email you use to log in to Jira
JIRA_EMAIL=your.email@company.com

# API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# Jira project key for the Reconciliation project
JIRA_PROJECT_KEY=R2026

# ── Auth (Google OAuth — @forusall.com only) ─────────────────────────────────
# Set REQUIRE_AUTH=false for local dev without login
REQUIRE_AUTH=true
SESSION_SECRET=generate-a-long-random-string-here
ALLOWED_EMAIL_DOMAIN=forusall.com

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect URI: https://<your-host>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: force redirect/callback base URL (Render sets X-Forwarded-* automatically)
# APP_BASE_URL=https://r2026-recon-dashboard.onrender.com
